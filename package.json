{
  "name": "chargecaster",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "bootstrap": "pnpm install",
    "build:domain": "pnpm --filter @chargecaster/domain build",
    "lint:domain": "pnpm --filter @chargecaster/domain lint",
    "lint:backend": "pnpm --filter chargecaster-backend lint",
    "typecheck:backend": "pnpm --filter chargecaster-backend typecheck",
    "build:backend": "pnpm --filter chargecaster-backend build",
    "lint:frontend": "pnpm --filter chargecaster-frontend lint",
    "typecheck:frontend": "pnpm --filter chargecaster-frontend typecheck",
    "build:frontend": "pnpm --filter chargecaster-frontend build",
    "lint:all": "pnpm run lint:domain && pnpm run lint:backend && pnpm run lint:frontend",
    "typecheck:all": "pnpm run typecheck:backend && pnpm run typecheck:frontend",
    "build:all": "pnpm run build:domain && pnpm run build:backend && pnpm run build:frontend",
    "dev": "concurrently -n backend,frontend -c blue,green \"pnpm --filter chargecaster-backend backend:dev:api\" \"VITE_TRPC_URL=http://localhost:4000/trpc pnpm --filter chargecaster-frontend dev\""
  },
  "devDependencies": {
    "@typescript-eslint/utils": "^8.58.0",
    "concurrently": "^9.2.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "jiti": "^2.6.1"
  },
  "pnpm": {
    "overrides": {
      "@nestjs/common>file-type": "21.3.2",
      "@nestjs/core>path-to-regexp": "8.4.0",
      "@nestjs/platform-fastify>fastify": "5.8.3",
      "@nestjs/platform-fastify>path-to-regexp": "8.4.0",
      "fdir>picomatch": "4.0.4",
      "flat-cache>flatted": "3.4.2",
      "micromatch>picomatch": "2.3.2",
      "minimatch@3.1.5>brace-expansion": "1.1.13",
      "minimatch@10.2.3>brace-expansion": "5.0.5",
      "minimatch@9.0.9>brace-expansion": "2.0.3",
      "minimatch@10.2.4>brace-expansion": "5.0.5",
      "vite>picomatch": "4.0.4",
      "vitest>picomatch": "4.0.4",
      "yaml": "2.8.3"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "better-sqlite3",
      "catboost",
      "esbuild"
    ]
  }
}
