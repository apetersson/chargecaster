dry_run: true

fronius:
  host: "http://inverter.invalid"
  user: "CHANGE_ME"
  password: "CHANGE_ME"
  verify_tls: false
  timeout_s: 6

evcc:
  enabled: true
  base_url: "http://evcc.invalid:7070"

price:
  energy:
    awattar:
      priority: 2
      url: "https://api.awattar.de/v1/marketdata"
      max_hours: 72
    # Optional ENTSO-E new-transparency provider (use at your own risk; unofficial API)
    # entsoe:
    #   priority: 1
    #   zone: "BZN|10YDE-ENBW-----N"
    #   tz: "CET"
    #   max_hours: 168
    #   aggregate_hourly: false
    from_evcc:
      priority: 3
  grid_fee:
    type: "e-control"
    netzbereich: "Wien"
    # Supported netzbereich values:
    # Burgenland, Graz, Innsbruck, Kärnten, Klagenfurt, Kleinwalsertal,
    # Linz, Niederösterreich, Oberösterreich, Salzburg, Steiermark,
    # Tirol, Vorarlberg, Wien
    # Current scope: Netzebene 7 / residential non-demand-metered only.
    # Stored as gross EUR/kWh and only for usage-dependent ct/kWh items.
    # Fixed Euro/Zählpunkt items stay out of the optimizer.
    # Static fallback:
    # type: "static"
    # eur_per_kwh: 0.1008
  feed_in:
    type: "awattar-sunny"
    # Static fallback:
    # type: "static"
    # eur_per_kwh: 0.05
    # Alternative hourly export pricing:
    # type: "awattar-sunny-spot"

location:
  latitude: 48.000
  longitude: 16.000
  timezone: "Europe/Vienna"

solar:
  - kwp: 5
    dec: 15
    az: -90
  - kwp: 5
    dec: 15
    az: 90

battery:
  capacity_kwh: 10
  chemistry: lifepo4
  max_charge_power_w: 500
  auto_mode_floor_soc: 5

logic:
  min_hold_minutes: 20     # debounce between flips
  interval_seconds: 300    # controller loop sleep

logging:
  level: "INFO" # ERROR, WARN, INFO, DEBUG, VERBOSE

load_forecast:
  model_dir: "../data/models/load-forecast"
  self_training_enabled: false
  python_executable: "python3"
