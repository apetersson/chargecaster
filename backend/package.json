{
  "name": "chargecaster-backend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "backend:dev": "tsx watch src/main.ts",
    "backend:dev:api": "SERVE_STATIC=false tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "start:api": "SERVE_STATIC=false tsx src/main.ts",
    "smoke:fronius-fast-charge": "tsx scripts/smoke-fronius-fast-charge.ts",
    "load-forecast:train": "tsx scripts/train-load-forecast.ts",
    "load-forecast:evaluate": "tsx scripts/evaluate-load-forecast.ts",
    "load-forecast:replay-evaluate": "tsx scripts/replay-load-forecast.ts",
    "load-forecast:promote": "tsx scripts/promote-load-forecast.ts",
    "load-forecast:bundle": "tsx scripts/bundle-load-forecast.ts",
    "price-forecast:train": "tsx scripts/train-price-forecast.ts",
    "bundle": "esbuild src/main.ts --platform=node --target=node20 --format=cjs --bundle --alias:@chargecaster/domain=../packages/domain/src/index.ts --external:better-sqlite3 --external:catboost --external:@nestjs/websockets/socket-module --external:@nestjs/microservices/microservices-module --external:@nestjs/microservices --external:@nestjs/platform-express --external:@fastify/view --external:class-validator --external:class-transformer --outfile=dist-bundle/index.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e"
  },
  "dependencies": {
    "@chargecaster/domain": "file:../packages/domain",
    "@fastify/cors": "11.2.0",
    "@fastify/static": "9.0.0",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.18",
    "@nestjs/platform-fastify": "11.1.18",
    "@trpc/server": "11.12.0",
    "catboost": "1.27.0",
    "better-sqlite3": "11.10.0",
    "fastify": "5.8.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "yaml": "2.8.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.18",
    "@trpc/client": "11.12.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.18.8",
    "@types/supertest": "2.0.16",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "esbuild": "0.27.3",
    "eslint": "9.37.0",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-import": "2.32.0",
    "globals": "15.15.0",
    "jiti": "2.6.1",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.1.3"
  }
}
